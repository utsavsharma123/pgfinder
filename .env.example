# ── Core ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-local-secret-key-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite (default for local dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/pg_finder

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AWS S3 ───────────────────────────────────────────────────────────────────
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1
# AWS_CLOUDFRONT_DOMAIN=

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
# SENDGRID_API_KEY=
# DEFAULT_FROM_EMAIL=noreply@pgfinder.in

# ── SMS (MSG91 or Twilio) ────────────────────────────────────────────────────
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# ── Maps ─────────────────────────────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=

# ── Payments ─────────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# ── Firebase Push ────────────────────────────────────────────────────────────
# FIREBASE_SERVER_KEY=
